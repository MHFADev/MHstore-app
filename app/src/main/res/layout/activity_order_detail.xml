<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar_detail"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/bg_surface"
            app:titleTextColor="@color/text_primary"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"/>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/content_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:padding="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── HEADER CARD ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:id="@+id/tv_order_id" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/text_primary" android:fontFamily="monospace" android:text="#ORDER-ID"/>
                        <TextView android:id="@+id/tv_status_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/status_pending" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:background="@drawable/bg_status_pending"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tv_service_badge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="@color/white" android:paddingHorizontal="10dp" android:paddingVertical="4dp" android:background="@drawable/bg_badge_blue" android:layout_marginTop="8dp"/>
                    <TextView android:id="@+id/tv_created_at" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="12sp" android:textColor="@color/text_secondary" android:layout_marginTop="6dp" android:text="—"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── CUSTOMER CARD ── -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="12dp" app:cardElevation="0dp" android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👤 Informasi Pelanggan" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary" android:layout_marginBottom="12dp"/>
                    <include layout="@layout/item_info_row" android:id="@+id/row_cust_name"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Customer details inline -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="12dp" app:cardElevation="0dp" android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👤 Data Pelanggan" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary" android:layout_marginBottom="12dp"/>

                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" app:boxBackgroundColor="@color/bg_raised" app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp" app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/et_cust_name" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Nama" android:textSize="13sp" android:textColor="@color/text_primary" android:inputType="textPersonName"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" app:boxBackgroundColor="@color/bg_raised" app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp" app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/et_cust_email" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Email" android:textSize="13sp" android:textColor="@color/text_primary" android:inputType="textEmailAddress"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" app:boxBackgroundColor="@color/bg_raised" app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp" app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/et_cust_wa" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="WhatsApp" android:textSize="13sp" android:textColor="@color/primary_light" android:inputType="phone"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" app:boxBackgroundColor="@color/bg_raised" app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp" app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/et_cust_city" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Kota" android:textSize="13sp" android:textColor="@color/text_primary" android:inputType="text"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" app:boxBackgroundColor="@color/bg_raised" app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp" app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/et_cust_biz" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Bisnis" android:textSize="13sp" android:textColor="@color/text_primary" android:inputType="text"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Action Buttons -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_wa_contact"
                            android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="💬 WhatsApp"
                            android:textSize="13sp"
                            app:backgroundTint="#1A37D366"
                            android:textColor="#37D366"
                            app:strokeColor="#37D366"
                            app:strokeWidth="1dp"
                            app:cornerRadius="8dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_marginEnd="6dp"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_copy_phone"
                            android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="📋 Salin No."
                            android:textSize="13sp"
                            app:backgroundTint="@color/bg_raised"
                            android:textColor="@color/text_secondary"
                            app:cornerRadius="8dp"
                            style="@style/Widget.MaterialComponents.Button.TextButton"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── SERVICE DETAILS CARD ── -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="12dp" app:cardElevation="0dp" android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📋 Detail Layanan" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary" android:layout_marginBottom="12dp"/>
                    <LinearLayout android:id="@+id/details_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"/>
                    <com.google.android.material.chip.ChipGroup android:id="@+id/chip_group_features" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── STATUS & NOTES CARD ── -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="12dp" app:cardElevation="0dp" android:layout_marginBottom="24dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚙️ Update Status" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary" android:layout_marginBottom="12dp"/>

                    <Spinner android:id="@+id/spin_status" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/bg_input" android:paddingHorizontal="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Catatan Admin" android:textSize="12sp" android:textColor="@color/text_secondary" android:layout_marginTop="16dp" android:layout_marginBottom="6dp"/>
                    <EditText
                        android:id="@+id/et_admin_notes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="80dp"
                        android:hint="Catatan internal (tidak terlihat pelanggan)..."
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="13sp"
                        android:padding="12dp"
                        android:background="@drawable/bg_input"
                        android:inputType="textMultiLine"
                        android:gravity="top"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_save_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Simpan Perubahan"
                        android:layout_marginTop="14dp"
                        app:backgroundTint="@color/primary"
                        app:cornerRadius="10dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
