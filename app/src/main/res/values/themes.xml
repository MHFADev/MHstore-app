<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── Base App Theme ── -->
    <style name="Theme.MHStoreAdmin" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_container</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorBackground">@color/bg_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorError">@color/colorError</item>

        <!-- Status/nav bars -->
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/bg_primary</item>

        <!-- Material overrides -->
        <item name="materialAlertDialogTheme">@style/MHAlertDialog</item>
        <item name="snackbarStyle">@style/MHSnackbar</item>
        <item name="chipStyle">@style/MHChip</item>
    </style>

    <!-- ── Splash Theme (no action bar, dark immersive) ── -->
    <style name="Theme.MHStoreAdmin.Splash" parent="Theme.MHStoreAdmin">
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowBackground">@color/bg_primary</item>
    </style>

    <!-- ── Alert Dialog ── -->
    <style name="MHAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:background">@color/bg_surface</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="materialAlertDialogTitleTextStyle">@style/MHAlertDialogTitle</item>
    </style>
    <style name="MHAlertDialogTitle" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- ── Snackbar ── -->
    <style name="MHSnackbar" parent="Widget.Material3.Snackbar">
        <item name="android:background">@color/bg_raised</item>
    </style>

    <!-- ── Chip ── -->
    <style name="MHChip" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipBackgroundColor">@color/primary_container</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

</resources>
